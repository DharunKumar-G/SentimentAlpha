# SentimentAlpha Configuration
# Copy this file to .env and fill in your API keys

# LLM Provider: "anthropic" or "openai" (finbert requires local install of torch+transformers)
LLM_PROVIDER=anthropic

# Anthropic (Claude) API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Anthropic Model (default: claude-sonnet-4-5)
ANTHROPIC_MODEL=claude-sonnet-4-5

# Database path
DATABASE_PATH=data/sentimentalpha.db

# News scraping interval (minutes)
SCRAPE_INTERVAL_MINUTES=30

# Dashboard port
DASHBOARD_PORT=8501

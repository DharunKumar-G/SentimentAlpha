# SentimentAlpha Configuration
# Copy this file to .env and fill in your API keys

# LLM Provider: "anthropic" or "openai" or "finbert" (free, no API key needed)
LLM_PROVIDER=finbert

# Anthropic (Claude) API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Anthropic Model (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Database path
DATABASE_PATH=data/sentimentalpha.db

# News scraping interval (minutes)
SCRAPE_INTERVAL_MINUTES=30

# Dashboard port
DASHBOARD_PORT=8501
